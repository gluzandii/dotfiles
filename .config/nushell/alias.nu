alias lg = lazygit
alias cat  = bat --paging=never

# Git aliases
alias gs = git status
alias ga = git add
alias gc = git commit
alias gp = git push
alias gl = git log
alias gb = git branch
alias gco = git checkout
alias gcm = git commit -m
alias gpf = git push -f
alias gaa = git add --all
alias gca = git commit --amend
alias gsw = git switch
alias gss = git stash
alias gwt = git worktree
alias gd = git diff
alias gr = git restore
alias gu = git undo
alias g = git

alias fzf = tv
