{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "tokensave": {
      "command": [
        "/opt/homebrew/bin/tokensave",
        "serve"
      ],
      "type": "local"
    }
  },
  "model": "ollama/qwen3-coder:30b",
  "provider": {
    "ollama": {
      "models": {
        "qwen3-coder:30b": {
          "_launch": true,
          "name": "qwen3-coder:30b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
